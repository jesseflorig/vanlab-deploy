# ============================================================================
# Home Assistant — Frigate Integration Configuration
# Generated by Ansible (nvr role) on {{ ansible_date_time.date }}
# ============================================================================
#
# HOW TO APPLY:
#   Option A — UI: In Home Assistant, go to Settings → Devices & Services →
#              Add Integration → search "Frigate" → enter the URL below.
#
#   Option B — YAML: Add the block below to your configuration.yaml and restart HA.
#
# After applying, Frigate camera entities will appear in Settings → Devices.
# Detection events will be available as MQTT topics under {{ nvr_mqtt_topic_prefix }}/#
# ============================================================================

# ── Frigate integration (configuration.yaml) ─────────────────────────────────
frigate:
  host: frigate.fleet1.cloud   # Public hostname via Traefik (HTTPS)
  # For internal access (bypasses Traefik): http://10.1.10.11:{{ nvr_frigate_port }}

# ── MQTT topics (for automations and sensors) ────────────────────────────────
# Detection events are published to: {{ nvr_mqtt_topic_prefix }}/<camera_name>/events
# Object snapshots:                  {{ nvr_mqtt_topic_prefix }}/<camera_name>/<object>/snapshot
# Camera state:                      {{ nvr_mqtt_topic_prefix }}/<camera_name>/motion

# ── Camera entities (auto-discovered after integration loads) ──────────────��──
{% if nvr_cameras | length > 0 %}
# The following cameras will appear as entities in Home Assistant:
{% for cam in nvr_cameras %}
#   - camera.{{ cam.name }} ({{ cam.width }}×{{ cam.height }})
#     Snapshot:  http://10.1.10.11:{{ nvr_frigate_port }}/api/{{ cam.name }}/latest.jpg
#     Stream:    http://10.1.10.11:{{ nvr_frigate_port }}/api/{{ cam.name }}/stream.m3u8
#     Events:    {{ nvr_mqtt_topic_prefix }}/{{ cam.name }}/events
{% endfor %}
{% else %}
# No cameras configured yet.
# Add nvr_cameras entries in group_vars/all.yml and re-run the playbook.
{% endif %}

# ── MQTT connection details (for reference) ───────────────────────────────────
# Broker IP:    {{ nvr_mqtt_broker_ip }}
# Broker port:  8883 (MQTTS)
# Topic prefix: {{ nvr_mqtt_topic_prefix }}
# Client ID:    {{ nvr_mqtt_client_id }}
