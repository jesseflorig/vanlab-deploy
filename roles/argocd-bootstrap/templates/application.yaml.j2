apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: "{{ item.name }}"
  namespace: "{{ argocd_namespace }}"
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  source:
    repoURL: "https://{{ gitea_hostname }}:{{ gitea_internal_port }}/{{ item.repo }}"
    targetRevision: "{{ item.revision | default('main') }}"
    path: "{{ item.path | default('.') }}"
  destination:
    server: https://kubernetes.default.svc
    namespace: "{{ item.namespace }}"
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
    retry:
      limit: 5
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m
