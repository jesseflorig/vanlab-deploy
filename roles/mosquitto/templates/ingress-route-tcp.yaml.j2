---
# Traefik IngressRouteTCP — routes MQTTS traffic on port 8883 to Mosquitto.
# TLS passthrough is required so Mosquitto can inspect client certificates (mTLS).
# The mqtts entrypoint must be configured in the Traefik Helm values (port 8883).
apiVersion: traefik.io/v1alpha1
kind: IngressRouteTCP
metadata:
  name: mosquitto-mqtts
  namespace: {{ mosquitto_namespace }}
spec:
  entryPoints:
    - mqtts
  routes:
    - match: HostSNI(`{{ mosquitto_hostname }}`)
      services:
        - name: mosquitto
          port: 8883
  tls:
    passthrough: true
