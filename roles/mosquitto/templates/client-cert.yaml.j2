---
# Parameterized cert-manager Certificate for MQTT client authentication.
# Issues a client certificate from the home-automation-ca internal ClusterIssuer.
# Variables:
#   cert_name       — Certificate resource name
#   cert_namespace  — Target namespace
#   cert_cn         — Common Name (used as MQTT username via use_identity_as_username)
#   cert_secret_name — Kubernetes Secret name for the issued cert
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: {{ cert_name }}
  namespace: {{ cert_namespace }}
spec:
  secretName: {{ cert_secret_name }}
  commonName: {{ cert_cn }}
  issuerRef:
    name: home-automation-ca
    kind: ClusterIssuer
  usages:
    - client auth
  duration: 8760h    # 1 year
  renewBefore: 720h  # Renew 30 days before expiry
